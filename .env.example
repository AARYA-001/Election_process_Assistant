# Backend — never commit real values
GEMINI_API_KEY=                        # Google AI Studio
GOOGLE_CIVIC_API_KEY=                  # Google Cloud Console (server-side only)
UPSTASH_REDIS_REST_URL=                # Upstash dashboard
UPSTASH_REDIS_REST_TOKEN=              # Upstash dashboard
ALLOWED_ORIGINS=http://localhost:5173  # Comma-separated list
SENTRY_DSN=                            # Sentry.io (optional but recommended)
NODE_ENV=development
PORT=3000

# Frontend (Vite — only VITE_ prefix is exposed to client)
VITE_GOOGLE_MAPS_API_KEY=              # HTTP referrer-locked in Google Cloud Console
VITE_API_BASE_URL=http://localhost:3000
